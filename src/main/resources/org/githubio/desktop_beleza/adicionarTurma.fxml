<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="500.0" prefWidth="700.0" stylesheets="@css/style.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1">

    <top>
        <AnchorPane prefHeight="80.0" style="-fx-background-color: #faf8f7;" BorderPane.alignment="CENTER">
            <children>
                <ImageView fx:id="imgLogo" fitHeight="52.0" fitWidth="83.0" layoutX="14.0" layoutY="26.0" pickOnBounds="true" preserveRatio="true">
                    <image>
                        <Image url="@Imagens/Senac_logo.png" />
                    </image>
                </ImageView>
            </children>
        </AnchorPane>
    </top>

    <center>
        <VBox alignment="CENTER" spacing="15.0" style="-fx-background-color: #0000;" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="20.0" left="40.0" right="40.0" top="10.0" />
            </padding>
            <children>
                <Label text="Registro de Turmas" textFill="#004587">
                    <font>
                        <Font name="Verdana Bold" size="26.0" />
                    </font>
                    <VBox.margin>
                        <Insets bottom="10.0" />
                    </VBox.margin>
                </Label>

                <VBox maxWidth="300.0" spacing="5.0">
                    <children>
                        <Label text="Nome da turma" textFill="#555555" />
                        <TextField fx:id="txtNomeTurma" prefHeight="35.0" promptText="Código - Nome do curso">
                            <tooltip>
                                <Tooltip text="Ex: 2025.08.133 - Técnico em DS" />
                            </tooltip>
                     <font>
                        <Font name="Verdana" size="12.0" />
                     </font>
                        </TextField>
                    </children>
                </VBox>

                <VBox maxWidth="300.0" spacing="5.0">
                    <children>
                        <Label text="Instrutor responsável" textFill="#555555" />
                        <ChoiceBox fx:id="comboInstrutor" prefHeight="35.0" prefWidth="300.0" />
                    </children>
                </VBox>

                <VBox maxWidth="300.0" spacing="5.0">
                    <children>
                        <Label text="Turno" textFill="#555555" />
                        <HBox fx:id="grupoTurno" spacing="10.0">
                            <children>
                                <Button fx:id="btnManha" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#selecionarManha" prefHeight="30.0" styleClass="btn-cinza" text="Manhã" HBox.hgrow="ALWAYS" />
                                <Button fx:id="btnTarde" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#selecionarTarde" prefHeight="30.0" styleClass="btn-cinza" text="Tarde" HBox.hgrow="ALWAYS" />
                                <Button fx:id="btnNoite" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#selecionarNoite" prefHeight="30.0" styleClass="btn-cinza" text="Noite" HBox.hgrow="ALWAYS" />
                            </children>
                        </HBox>
                    </children>
                </VBox>

                <CheckBox mnemonicParsing="false" text="Trabalha em mais de uma turma?">
                    <VBox.margin>
                        <Insets top="5.0" />
                    </VBox.margin>
                </CheckBox>

                <VBox alignment="CENTER" spacing="10.0">
                    <VBox.margin>
                        <Insets top="10.0" />
                    </VBox.margin>
                    <children>
                        <Button fx:id="clicouFinalizar" minWidth="200.0" mnemonicParsing="false" onAction="#finalizarESair" prefHeight="40.0" styleClass="btn-azul" text="Finalizar e Sair" textFill="WHITE" />
                        <Button fx:id="clicouRegistrarOutra" minWidth="200.0" mnemonicParsing="false" onAction="#registrarOutra" prefHeight="35.0" styleClass="btn-cinza" text="Registrar outra turma" textFill="#004587" />
                    </children>
                </VBox>
            </children>
        </VBox>
    </center>

    <left>
        <AnchorPane prefWidth="100.0" style="-fx-background-color: #faf8f7;" BorderPane.alignment="CENTER" />
    </left>
    <right>
        <AnchorPane prefWidth="100.0" style="-fx-background-color: #faf8f7;" BorderPane.alignment="CENTER" />
    </right>
    <bottom>
        <AnchorPane prefHeight="40.0" style="-fx-background-color: #faf8f7;" BorderPane.alignment="CENTER" />
    </bottom>
</BorderPane>
