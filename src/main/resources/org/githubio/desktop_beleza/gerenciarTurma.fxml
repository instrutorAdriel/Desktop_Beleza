<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="600.0" prefWidth="950.0" stylesheets="@style.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.githubio.desktop_beleza.controller.GerenciarTurmaController">
   <top>
      <Pane prefHeight="70.0" prefWidth="600.0" BorderPane.alignment="CENTER">
         <children>
            <ImageView fitHeight="52.0" fitWidth="83.0" layoutX="14.0" layoutY="14.0" pickOnBounds="true" preserveRatio="true">
               <image>
                  <Image url="@Imagens/Senac_logo.png" />
               </image>
            </ImageView>
         </children>
      </Pane>
   </top>

   <left>
      <VBox prefWidth="180.0" spacing="10.0" style="-fx-background-color: #faf8f7; -fx-border-color: #E1E3E2; -fx-border-width: 0 1 0 0;" BorderPane.alignment="CENTER">
         <padding>
            <Insets top="20.0" />
         </padding>
         <children>
            <VBox spacing="8.0">
               <padding>
                  <Insets left="15.0" right="15.0" />
               </padding>
               <children>
                  <Button fx:id="buscarTurmas" maxWidth="1.7976931348623157E308" mnemonicParsing="false" styleClass="accent" text="Página inicial">
                     <font>
                        <Font name="Verdana" size="12.0" />
                     </font></Button>
                  <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" styleClass="accent" text="Clientes">
                     <font>
                        <Font name="Verdana" size="12.0" />
                     </font></Button>
                  <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" styleClass="accent" text="Serviços" />
                  <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" styleClass="accent" text="Turmas">
                     <font>
                        <Font name="Verdana" size="12.0" />
                     </font></Button>
               </children>
            </VBox>
            <VBox VBox.vgrow="ALWAYS" />
            <VBox alignment="CENTER" prefHeight="80.0">
               <children>
                  <Button minWidth="100.0" mnemonicParsing="false" styleClass="danger" text="Sair">
                     <font>
                        <Font name="Verdana" size="12.0" />
                     </font></Button>
               </children>
            </VBox>
         </children>
      </VBox>
   </left>

   <center>
      <VBox spacing="20.0" style="-fx-background-color: #ffffff;" BorderPane.alignment="CENTER">
         <padding>
            <Insets bottom="25.0" left="30.0" right="30.0" top="25.0" />
         </padding>
         <children>
            <Label alignment="CENTER" text="Gerenciamento de Turmas" textFill="#004587">
               <font>
                  <Font name="Verdana Bold" size="24.0" />
               </font>
               <VBox.margin>
                  <Insets left="100.0" />
               </VBox.margin>
            </Label>

            <HBox alignment="CENTER_LEFT" spacing="15.0">
               <children>
                  <TextField fx:id="txtBusca" prefHeight="35.0" promptText="Buscar..." style="-fx-background-color: #E1E3E2;" HBox.hgrow="ALWAYS" />
                  <Button minHeight="35.0" mnemonicParsing="false" onAction="#abrirTelaCadastroPopUp" prefWidth="150.0" text="Adicionar Turma" />
               </children>
            </HBox>

            <TableView fx:id="tabelaUsuarios" VBox.vgrow="ALWAYS">
               <columns>
                  <TableColumn fx:id="colTurma" prefWidth="200.0" text="Nome/Código" />
                  <TableColumn fx:id="colTurno" prefWidth="100.0" text="Turno" />
                  <TableColumn fx:id="colInstrutor" prefWidth="150.0" text="Instrutores" />
                  <TableColumn fx:id="colStatus" prefWidth="100.0" text="Status" />
                  <TableColumn fx:id="colAcoes" prefWidth="100.0" text="Ações" />
               </columns>
               <columnResizePolicy>
                  <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
               </columnResizePolicy>
            </TableView>
         </children>
      </VBox>
   </center>
   <right>
      <Pane prefHeight="400.0" prefWidth="140.0" style="-fx-background-color: #faf8f7;" BorderPane.alignment="CENTER" />
   </right>
   <bottom>
      <Pane prefHeight="70.0" prefWidth="600.0" BorderPane.alignment="CENTER" />
   </bottom>
</BorderPane>
